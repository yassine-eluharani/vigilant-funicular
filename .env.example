# ApplyPilot Environment Configuration
# Copy this file to .env and fill in your values.
# In Docker: these are stored in the /data volume (mounted at ./data/)

# ── LLM Provider (pick one) ──────────────────────────────────────────────────
GEMINI_API_KEY=           # Gemini 2.5 Flash (recommended, cheapest)
# OPENAI_API_KEY=         # OpenAI (GPT-4o-mini)
# LLM_URL=http://127.0.0.1:8080/v1  # Local LLM (llama.cpp, Ollama)
# LLM_MODEL=              # Override model name (e.g. gemini-2.5-pro)

# ── Auto-Apply (optional, Tier 3) ────────────────────────────────────────────
CAPSOLVER_API_KEY=        # For CAPTCHA solving during auto-apply

# ── Proxy (optional, for scraping) ───────────────────────────────────────────
# PROXY=host:port:user:pass

# ── Authentication (Clerk) ────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Webhook signing secret (Clerk dashboard → Webhooks → your endpoint → Signing Secret)
CLERK_WEBHOOK_SECRET=whsec_...
# Optional: override JWKS URL if Clerk can't derive it from the publishable key
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# ── Docker / Deployment ──────────────────────────────────────────────────────
# DATA_DIR=./data           # Host path for the persistent data volume
# FRONTEND_ORIGIN=https://yourdomain.com  # For CORS in production
