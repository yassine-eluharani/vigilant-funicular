# ApplyPilot Environment Configuration
# Copy this file to .env and fill in your values.
# In Docker: these are stored in the /data volume (mounted at ./data/).

# ════════════════════════════════════════════════════════════════════════════
# Required (deploy-time)
# ════════════════════════════════════════════════════════════════════════════

# ── Authentication (Clerk) ────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── Database (Turso / libSQL) ─────────────────────────────────────────────────
# Required for production. Omit to fall back to local SQLite under $APPLYPILOT_DIR.
DATABASE_URL=libsql://your-db.turso.io
DATABASE_TOKEN=

# ── LLM Provider (at least one required for scoring/tailoring) ────────────────
GEMINI_API_KEY=           # Gemini 2.5 Flash (recommended, cheapest)
# OPENAI_API_KEY=         # OpenAI alternative (e.g. gpt-4o-mini)
# LLM_MODEL=              # Override model name (e.g. gemini-2.5-pro)
# LLM_URL=http://127.0.0.1:8080/v1  # Local LLM (llama.cpp, Ollama)

# ════════════════════════════════════════════════════════════════════════════
# Optional
# ════════════════════════════════════════════════════════════════════════════

# ── Clerk extras ──────────────────────────────────────────────────────────────
# Webhook signing secret (Clerk dashboard → Webhooks → your endpoint → Signing Secret)
CLERK_WEBHOOK_SECRET=whsec_...
# Override JWKS URL if Clerk can't derive it from the publishable key
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# Pin the expected JWT audience (`aud` claim). Clerk uses `azp` by default so
# audience validation is opt-in. If set, tokens whose `aud` does not match are
# rejected. Leave unset to skip `aud` validation (issuer pinning still blocks
# cross-tenant tokens). Configure this in your Clerk JWT template.
# CLERK_AUDIENCE=applypilot

# ── Stripe (enables paid Pro upgrades) ────────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Dashboard → Products → your product → Pricing → click the price row to reveal price_...
STRIPE_PRICE_ID=price_...
# Local dev: run `stripe listen --forward-to localhost:8000/api/stripe/webhook`
# and copy the whsec_... it prints. Production: Dashboard → Webhooks → Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_...
# Where Stripe redirects after checkout. Use http:// for localhost, https:// for prod.
STRIPE_SUCCESS_URL=http://localhost:3000/jobs?upgraded=true
STRIPE_CANCEL_URL=http://localhost:3000/pricing

# ── Email notifications (one of the two — Resend preferred) ───────────────────
RESEND_API_KEY=re_...
# SMTP fallback (only used if RESEND_API_KEY is unset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ── Networking / CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the FastAPI backend.
# Wildcard ('*') is rejected — refuses to start in production.
CORS_ORIGINS=https://yourdomain.com
# The public origin of the frontend (used by nginx, Stripe redirects, etc.)
FRONTEND_ORIGIN=https://yourdomain.com

# ── Storage / paths ───────────────────────────────────────────────────────────
# Directory for SQLite/profile/resume files. Defaults to ~/.applypilot.
# In Docker, this is mapped to the `data` volume at /data.
APPLYPILOT_DIR=/data
# DATA_DIR=./data           # Host path for the persistent data volume

# ── Domain (used by nginx + setup-ssl.sh) ─────────────────────────────────────
# DOMAIN=yourdomain.com
